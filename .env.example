# Configuration untuk Smart Diabetes
# Copy file ini ke .env dan sesuaikan nilai-nilainya

# Flask Secret Key (GANTI dengan random string untuk production!)
SECRET_KEY=your-secret-key-change-this-in-production-use-secrets-token-hex-32

# Database URL (SQLite by default)
DATABASE_URL=sqlite:///smartdiabetes.db

# Flask Environment (development/production)
FLASK_ENV=development
FLASK_DEBUG=True

# Admin Default Credentials (untuk inisialisasi pertama kali)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@smartdiabetes.com
ADMIN_PASSWORD=admin123
